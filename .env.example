# 환경변수 템플릿 — 실제 값은 각자 발급받아 .env 에 채우세요. (.env 는 git 무시됨)
# 이 프로젝트는 공개 임대 데이터 수집/가공 파이프라인(Python) + 웹(web/, Next.js)으로 구성됩니다.
# ※ 웹 MVP는 로컬 SQLite(web/data/lease.db)만으로 동작하므로 아래 키 없이도 웹 구동은 가능합니다.
#    아래 키는 데이터 수집·지오코딩·보강(Python cli.py) 및 원격 Supabase 사용 시 필요합니다.

# ── Supabase (원격 DB 사용 시. MVP는 로컬 SQLite라 불필요) ──
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=
SUPABASE_DB_USER=
SUPABASE_DB_PASSWORD=

# ── 웹 클라이언트 공개 변수 (web/.env.local 에 설정. NEXT_PUBLIC_* 는 브라우저 노출) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_KAKAO_JS_KEY=

# ── 카카오 (지도 표시=JS키, 로컬 REST=REST키) https://developers.kakao.com ──
KAKAO_REST_API_KEY=
KAKAO_JS_KEY=

# ── VWORLD 지오코딩 (주소→좌표) https://www.vworld.kr ──
VWORLD_KEY=
VWORLD_DOMAIN=localhost

# ── 공공데이터포털 (건축물대장·인구·상권) https://www.data.go.kr ──
DATAGO_SERVICE_KEY=
STDG_PPLTN_BASE_URL=https://apis.data.go.kr/1741000/stdgPpltnHhStus
ADMM_PPLTN_BASE_URL=https://apis.data.go.kr/1741000/admmPpltnHhStus

# ── 네이버 검색 API (뉴스 수집) https://developers.naver.com ──
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
